{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)/server\" && go fmt ./...",
            "timeout": 30,
            "statusMessage": "Formatting Go server"
          }
        ]
      }
    ]
  }
}
